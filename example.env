ENVIRONMENT=development



# --- Configurações do MongoDB ---
# URI para conexão com MongoDB.
# Para usar Atlas:
# MONGO_URI = "mongodb+srv://<username>:<password>@<database>.mongodb.net/?retryWrites=true&w=majority&appName=<database_name>"

#Caso não tenha a MONGO_URI a aplicação tenta conectar no banco local (Docker)


# Nome do banco de dados (usado se MONGO_URI não contiver /dbname)
DB_NAME=

# Timeouts para conexão (valores em milissegundos)
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
MONGO_CONNECT_TIMEOUT_MS=10000

# --- Configurações do MongoDB Local (usado apenas com --profile local) ---
MONGO_PORT=27017
MONGO_USERNAME=
MONGO_PASSWORD=

# --- Configurações do Mongo Express (usado apenas com --profile local) ---
MONGO_EXPRESS_PORT=8081
ME_BASICAUTH_USERNAME=
ME_BASICAUTH_PASSWORD=

# --- Configurações da API ---
API_PORT=8000

# Chave de API para proteção dos endpoints (opcional, depende da implementação)
API_KEY=
API_KEY_NAME = "X-API-Key"
MASTER_KEY = ""

# --- Configurações de Logging ---
LOG_LEVEL=INFO

# --- Configurações de Retry para conexão com MongoDB ---
MONGO_MAX_RETRIES=3
MONGO_RETRY_DELAY=2

# --- Configurações de Retry para validar a saúde da API
HEALTH_READY_TTL=10

DISABLE_FILE_LOGGING=true
